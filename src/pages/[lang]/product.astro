---

import { getEntry, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import MainGridLayout from "../../layouts/MainGridLayout.astro";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "vi" } },
	];
}


const productPost = await getEntry("spec", "product");

if (!productPost) {
	throw new Error("product page content not found");
}

const { Content } = await render(productPost);
---
<MainGridLayout title={i18n(I18nKey.product, Astro.currentLocale)} description={i18n(I18nKey.product, Astro.currentLocale)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>