---
import { getCollection, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../../../layouts/MainGridLayout.astro";

export async function getStaticPaths() {
	const products = await getCollection("products");
	
	return products.flatMap((product) => [
		{
			params: { lang: "en", slug: product.slug },
			props: { product },
		},
		{
			params: { lang: "vi", slug: product.slug },
			props: { product },
		},
	]);
}

const { product } = Astro.props;
const { Content } = await render(product);
const techStacks = Array.isArray(product.data.techStack)
	? product.data.techStack
	: typeof product.data.techStack === "string"
	? product.data.techStack.split(",").map((item) => item.trim()).filter(Boolean)
	: [];
const tags = Array.isArray(product.data.tags)
	? product.data.tags
	: typeof product.data.tags === "string"
	? product.data.tags.split(",").map((item) => item.trim()).filter(Boolean)
	: [];
---

<MainGridLayout title={product.data.title} description={product.data.description}>
	<article class="w-full">
		{product.data.image && (
			<div class="w-full h-96 rounded-[var(--radius-large)] overflow-hidden mb-8">
				<img 
					src={product.data.image} 
					alt={product.data.title}
					class="w-full h-full object-cover"
				/>
			</div>
		)}
		
		<div class="card-base rounded-[var(--radius-large)] p-9">
			<h1 class="text-4xl font-bold mb-4">{product.data.title}</h1>
			<div class="flex flex-wrap gap-2 mb-8">
				{product.data.category && (
					<span class="text-sm bg-gray-200 dark:bg-gray-700 px-3 py-1 rounded">
						{product.data.category}
					</span>
				)}
				{product.data.status && (
					<span class="text-sm bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 px-3 py-1 rounded">
						{product.data.status}
					</span>
				)}
				{product.data.type && (
					<span class="text-sm bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 px-3 py-1 rounded">
						{product.data.type}
					</span>
				)}
				{product.data.platform && (
					<span class="text-sm bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 px-3 py-1 rounded">
						{product.data.platform}
					</span>
				)}
			</div>
			<div class="grid gap-4 mb-8 pb-8 border-b md:grid-cols-2">
				{product.data.demo && (
					<div>
						<p class="text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400 mb-2">Demo</p>
						<a href={product.data.demo} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-300 font-medium hover:text-blue-500 transition-colors">
							View demo
						</a>
					</div>
				)}
				{techStacks.length > 0 && (
					<div>
						<p class="text-sm uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400 mb-3">Tech stack</p>
						<div class="flex flex-wrap gap-2">
							{techStacks.map((tech) => (
								<span class="text-xs bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full">
									{tech}
								</span>
							))}
						</div>
					</div>
				)}
			</div>
			<Markdown>
				<Content />
			</Markdown>
			
			{tags.length > 0 && (
				<div class="mt-8 pt-8 border-t">
					<div class="flex flex-wrap gap-2">
						{tags.map((tag) => (
							<span class="text-xs bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full">
								{tag}
							</span>
						))}
					</div>
				</div>
			)}
		</div>
	</article>
</MainGridLayout>