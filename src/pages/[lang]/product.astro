---
import { getCollection } from "astro:content";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "vi" } },
	];
}

const lang = Astro.params.lang;
const products = await getCollection("products", ({ data }) => {
	return !data.draft && (data.lang === "" || data.lang === lang);
});
---

<MainGridLayout 
	title={i18n(I18nKey.product, Astro.currentLocale)} 
	description={i18n(I18nKey.product, Astro.currentLocale)}
>
	<div class="w-full">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{products.map((product) => (
				<a 
					href={`/${lang}/products/${product.slug}`}
					class="card-base rounded-[var(--radius-large)] overflow-hidden hover:shadow-lg transition-shadow"
				>
					{product.data.image && (
						<div class="w-full h-48 overflow-hidden">
							<img 
								src={product.data.image} 
								alt={product.data.title}
								class="w-full h-full object-cover hover:scale-105 transition-transform"
							/>
						</div>
					)}
					<div class="p-6">
						<h3 class="text-lg font-bold mb-2">{product.data.title}</h3>
						<p class="text-sm opacity-75 mb-4 line-clamp-2">{product.data.description}</p>
						<div class="flex flex-wrap gap-2 mb-4">
							{product.data.type && (
								<span class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 px-2 py-1 rounded">
									{product.data.type}
								</span>
							)}
							{product.data.platform && (
								<span class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 px-2 py-1 rounded">
									{product.data.platform}
								</span>
							)}
							{product.data.status && (
								<span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 px-2 py-1 rounded">
									{product.data.status}
								</span>
							)}
						</div>
						<div class="flex justify-between items-center">
							{product.data.category && (
								<span class="text-xs bg-gray-200 dark:bg-gray-700 px-2 py-1 rounded">
									{product.data.category}
								</span>
							)}
							{product.data.demo && (
								<span class="text-xs font-medium text-blue-500">
									Demo available
								</span>
							)}
						</div>
					</div>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>