---
import { getCollection, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "../../../../layouts/MainGridLayout.astro";

export async function getStaticPaths() {
	const appArticles = await getCollection("appArticles");

	return appArticles.flatMap((article) => [
		{
			params: { lang: article.data.lang || "en", app: article.data.app, article: article.slug },
			props: { article },
		},
	]);
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<MainGridLayout title={article.data.title} description={article.data.description}>
	<article class="w-full">
		{article.data.image && (
			<div class="w-full h-96 rounded-[var(--radius-large)] overflow-hidden mb-8">
				<img
					src={article.data.image}
					alt={article.data.title}
					class="w-full h-full object-cover"
				/>
			</div>
		)}

		<div class="card-base rounded-[var(--radius-large)] p-9">
			<h1 class="text-4xl font-bold mb-4">{article.data.title}</h1>

			<div class="flex flex-wrap gap-2 mb-8">
				{article.data.category && (
					<span class="text-sm bg-gray-200 dark:bg-gray-700 px-3 py-1 rounded">
						{article.data.category}
					</span>
				)}
				{article.data.app && (
					<span class="text-sm bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200 px-3 py-1 rounded">
						App: {article.data.app}
					</span>
				)}
			</div>

			<Markdown>
				<Content />
			</Markdown>

			{article.data.tags && article.data.tags.length > 0 && (
				<div class="mt-8 pt-8 border-t">
					<div class="flex flex-wrap gap-2">
						{article.data.tags.map((tag) => (
							<span class="text-xs bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full">
								{tag}
							</span>
						))}
					</div>
				</div>
			)}
		</div>
	</article>
</MainGridLayout>